default_platform(:ios)

XCODE_PROJECT   = "./ios/App/App.xcodeproj"
XCODE_WORKSPACE = "./ios/App/App.xcworkspace"
SCHEME          = "App"
BUNDLE_ID       = "com.trizone.app"

platform :ios do
  desc "Build the app and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: ENV.fetch("API_KEY_PATH"),
      in_house: false
    )

    setup_ci if ENV["CI"]

    keychain_password = ENV["MATCH_KEYCHAIN_PASSWORD"] || ""

    # 배포 인증서(.p12)를 CI 키체인에 가져온다.
    # fastlane `cert`로 매번 새 인증서를 만들면 Apple의 배포 인증서 개수 한도에 부딪혀
    # "Could not create another Distribution certificate" 로 실패한다.
    # 따라서 미리 내보낸 .p12를 GitHub Secret(BUILD_CERTIFICATE_BASE64 / P12_PASSWORD)으로
    # 주입해 동일 인증서를 재사용한다. (워크플로의 "Import signing certificate" 스텝 참고)
    import_certificate(
      certificate_path: ENV.fetch("CERTIFICATE_PATH"),
      certificate_password: ENV["P12_PASSWORD"] || "",
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: keychain_password
    )

    sigh(
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      output_path: "./fastlane/profiles",
      force: true
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODE_PROJECT,
      bundle_identifier: BUNDLE_ID,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: [SCHEME]
    )

    marketing_version = ENV.fetch("MARKETING_VERSION")

    increment_version_number(
      xcodeproj: XCODE_PROJECT,
      version_number: marketing_version
    )

    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      initial_build_number: 0,
      version: marketing_version
    )

    increment_build_number(
      xcodeproj: XCODE_PROJECT,
      build_number: latest_build + 1
    )

    build_app(
      workspace: XCODE_WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Trizone.ipa",
      clean: true,
      buildlog_path: "./build/logs",
      export_options: {
        provisioningProfiles: {
          BUNDLE_ID => profile_name
        },
        signingStyle: "manual",
        teamID: ENV.fetch("APPLE_TEAM_ID")
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
