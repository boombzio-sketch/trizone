default_platform(:ios)

XCODE_PROJECT   = "./ios/App/App.xcodeproj"
XCODE_WORKSPACE = "./ios/App/App.xcworkspace"
SCHEME          = "App"
BUNDLE_ID       = "com.trizone.app"

platform :ios do
  desc "Build the app and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: ENV.fetch("API_KEY_PATH"),
      in_house: false
    )

    setup_ci if ENV["CI"]

    keychain_password = ENV["MATCH_KEYCHAIN_PASSWORD"] || ""

    # fastlane match: 배포 인증서 + 프로비저닝 프로파일을 git(이 저장소의 match-certs 브랜치)에
    # AES 암호화 저장하고 재사용한다. fastlane `cert`처럼 매 빌드마다 새 인증서를 만들지 않으므로
    # Apple 배포 인증서 개수 한도에 다시 걸리지 않는다. (Mac 불필요 — CI에서 생성/재사용)
    #   첫 실행: 인증서 1개 생성(빈 슬롯 1칸 필요) → git에 저장
    #   이후 실행: 저장된 인증서/프로파일을 그대로 설치해 재사용
    # git 접근은 워크플로의 GITHUB_TOKEN 기반 MATCH_GIT_BASIC_AUTHORIZATION 으로 처리(PAT 불필요).
    match(
      type: "appstore",
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      storage_mode: "git",
      git_url: ENV.fetch("MATCH_GIT_URL"),
      git_branch: ENV["MATCH_GIT_BRANCH"] || "match-certs",
      readonly: false,
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: keychain_password
    )

    # match가 설치한 App Store 프로비저닝 프로파일 이름
    profile_name = ENV.fetch("sigh_#{BUNDLE_ID}_appstore_profile-name")

    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODE_PROJECT,
      bundle_identifier: BUNDLE_ID,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: [SCHEME]
    )

    marketing_version = ENV.fetch("MARKETING_VERSION")

    increment_version_number(
      xcodeproj: XCODE_PROJECT,
      version_number: marketing_version
    )

    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      initial_build_number: 0,
      version: marketing_version
    )

    increment_build_number(
      xcodeproj: XCODE_PROJECT,
      build_number: latest_build + 1
    )

    build_app(
      workspace: XCODE_WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Trizone.ipa",
      clean: true,
      buildlog_path: "./build/logs",
      export_options: {
        provisioningProfiles: {
          BUNDLE_ID => profile_name
        },
        signingStyle: "manual",
        teamID: ENV.fetch("APPLE_TEAM_ID")
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
