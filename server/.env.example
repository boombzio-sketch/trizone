# Postgres connection string (Neon, Render Postgres, Supabase, etc.)
# Neon example: postgresql://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# JWT signing secret. Use a long random string in production.
JWT_SECRET=trizone_secret_2025

# Optional: extra allowed CORS origin (the deployed client URL is already whitelisted)
# CLIENT_URL=https://your-client.example.com

# Server port (default 3001)
# PORT=3001
